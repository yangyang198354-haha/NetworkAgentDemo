# NetworkAgentDemo — Environment Variables
# Copy this file to .env and fill in your API keys

# DeepSeek API Key (required for LLM calls)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# OpenAI API Key (required for Chroma embeddings — DeepSeek may not provide embedding endpoint)
# If not set, RAGService falls back to in-memory keyword matching
OPENAI_API_KEY=sk-your-openai-api-key

# Configuration file path (default: ./config/config.yaml)
CONFIG_PATH=./config/config.yaml

# Device-specific passwords (override config.yaml device passwords)
# Format: DEVICE_{DEVICE_NAME}_PASSWORD
DEVICE_CORE-SW-01_PASSWORD=admin123
DEVICE_ACCESS-SW-02_PASSWORD=admin123
